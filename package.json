{
  "name": "visa-info-mcp",
  "version": "1.0.2",
  "description": "MCP server providing visa requirements, processing times, and documents for Indian passport holders. Data sourced from timesofvisa.com.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "visa-info-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "keywords": [
    "mcp",
    "visa",
    "india",
    "travel",
    "immigration",
    "timesofvisa"
  ],
  "author": "Times of Visa <noreply@timesofvisa.com>",
  "license": "MIT",
  "homepage": "https://www.timesofvisa.com",
  "mcpName": "io.github.rajat79suri/visa-info",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^20.0.0",
    "agents": "^0.8.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.77.0"
  }
}
