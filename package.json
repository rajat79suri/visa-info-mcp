{
  "name": "visa-info-mcp",
  "version": "1.0.0",
  "description": "MCP server providing visa requirements, processing times, and documents for Indian passport holders. Data sourced from timesofvisa.com.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "visa-info-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": ["mcp", "visa", "india", "travel", "immigration", "timesofvisa"],
  "author": "Times of Visa <noreply@timesofvisa.com>",
  "license": "MIT",
  "homepage": "https://www.timesofvisa.com",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
